# Environment variables for the EDR Telemetry Cloud Function
# Copy this file to .env.yaml and fill in the real values.
# .env.yaml is git-ignored and must never be committed.

# Supabase Configuration
SUPABASE_URL: "https://<your-project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY: "<your-service-role-key>"

# Webhook secret — must match the WEBHOOK_SECRET GitHub Actions secret.
# Generate a new one with: openssl rand -hex 32
WEBHOOK_SECRET: "<your-webhook-secret>"
